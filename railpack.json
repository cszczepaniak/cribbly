{
  "$schema": "https://schema.railpack.com",
  "caches": {
    "npm": {
      "directory": "/root/.npm",
      "type": "shared"
    }
  },
  "steps": {
    "build": {
      "commands": [
        "npm install",
        "npm run frontend:install",
        "npm run frontend:build",
        "..."
      ],
      "caches": ["...", "npm"]
    }
  }
}
